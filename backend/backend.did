type UserRecord = 
 record {
   addedAt: Time;
   addedBy: principal;
   role: Role;
   suspended: bool;
 };
type Time = int;
type ThePractice = 
 service {
   addUser: (p: principal, role: Role) -> (Result);
   getMasterController: () -> (principal) query;
   getMyRole: () -> (opt Role) query;
   getOperationsPrincipal: () -> (opt principal) query;
   getUserCount: () -> (nat) query;
   grantOperations: (p: principal) -> (Result);
   listUsers: () -> (vec record {
                           principal;
                           UserRecord;
                         }) query;
   readAuditEntries: (after: nat, limit: nat) -> (Result_1);
   removeUser: (p: principal) -> (Result);
   revokeOperations: () -> (Result);
   setUserRole: (p: principal, role: Role) -> (Result);
   suspendUser: (p: principal) -> (Result);
   transferMasterController: (p: principal) -> (Result);
   unsuspendUser: (p: principal) -> (Result);
   whoAmI: () -> (principal) query;
 };
type Role = 
 variant {
   Associate;
   Partner;
   Staff;
 };
type Result_1 = 
 variant {
   err: text;
   ok: vec AuditEntry;
 };
type Result = 
 variant {
   err: text;
   ok;
 };
type AuditOutcome = 
 variant {
   err: text;
   ok;
 };
type AuditEntry = 
 record {
   action: text;
   caller: principal;
   id: nat;
   outcome: AuditOutcome;
   target: opt principal;
   timestamp: Time;
 };
service : (masterControllerArg: principal) -> ThePractice
